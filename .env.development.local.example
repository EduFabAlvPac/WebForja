# Configuracion de desarrollo local
# Copia este archivo como .env.development.local si trabajas detras de un proxy corporativo

# SOLO PARA DESARROLLO LOCAL - Desactiva verificacion SSL
# Necesario si tu red corporativa usa certificados auto-firmados
NODE_TLS_REJECT_UNAUTHORIZED=0

# Analytics (desactivado en desarrollo)
NEXT_PUBLIC_GA_ID=

# URLs de API
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Contacto (teléfono, WhatsApp y email mostrados en el portal)
# NEXT_PUBLIC_CONTACT_PHONE=+57 312 2415413
# NEXT_PUBLIC_WHATSAPP_NUMBER=573122415413
# NEXT_PUBLIC_CONTACT_EMAIL=contacto@forjaconsulting.com

# Formulario de contacto → Google Sheets (hoja LEADS)
# URL del Web App de Google Apps Script que recibe el POST
NEXT_PUBLIC_GOOGLE_SHEETS_ENDPOINT=

# Herramienta Evaluación de Madurez (carpeta TestMadurezEmpresarial)
# En local: arranca con "pnpm dev" o "npm run dev" en TestMadurezEmpresarial (ej. puerto 3001)
# Ejemplo: http://localhost:3001/evaluacion
NEXT_PUBLIC_EVALUACION_MADUREZ_URL=
